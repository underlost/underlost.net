---
const { url, title, description, settings } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url,
  name: title,
  description,
  ...(settings?.logo ? {
    publisher: {
      "@type": "Organization",
      logo: {
        "@type": "ImageObject",
        url: settings.logo
      }
    }
  } : {})
};

const schemaJson = JSON.stringify(schema, null, 2);
---

<script type="application/ld+json">
  <Fragment set:html={schemaJson} />
</script>
