---
import EntryCard from "@/components/entries/EntryCard.astro";

const { title, posts, className, cardClass, collectionPath } = Astro.props;
---

<section class={`${className} px-4 lg:px-8 py-16`}>
  {title && <h2 class="h1 text-center uppercase">{title}</h2>}

  <div class="max-w-5xl mx-auto -translate-y-4 lg:-translate-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-11">
      {
        posts.map((post: any, i: any) => (
          <div class="col-span-1">
            <div class="lg:h-full flex flex-col justify-between">
              <EntryCard
                entry={post}
                num={i}
                collectionPath={collectionPath}
                className={cardClass}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
