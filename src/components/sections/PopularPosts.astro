---
import { getPopularPosts } from "@/utils/ghost";
import EntryGrid from "@/components/entries/EntryGrid.astro";
const posts = await getPopularPosts({ limit: 6, page: 1 });

const { className } = Astro.props;
const classes = className ? ` ${className}` : "tag-color-scheme-d";
---

<EntryGrid
  title="Popular Posts"
  className={classes}
  posts={posts}
  collectionPath="writing/"
/>
