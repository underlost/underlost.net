---
import { getPosts } from "@/utils/ghost";
import EntryGrid from "@/components/entries/EntryGrid.astro";
const posts = await getPosts({ limit: 6, page: 1 });

const { className } = Astro.props;
const classes = className ? ` ${className}` : "tag-color-scheme-c";
---

<EntryGrid
  title="Recent Posts"
  className={classes}
  posts={posts}
  collectionPath="writing/"
/>
