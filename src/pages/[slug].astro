---
import type { PostOrPage } from "@tryghost/content-api";
import { getAllPages } from "@/utils/ghost";
import { BodyClass } from "@/utils/BodyClass";
import PageLayout from "@/layouts/PageLayout.astro";
import FullPageLayout from "@/layouts/FullPageLayout.astro";

export async function getStaticPaths() {
  const pages = await getAllPages();

  return pages.map((page) => {
    return {
      params: {
        slug: page.slug,
      },
      props: {
        page: page,
      },
    };
  });
}

const page = Astro.props.page as PostOrPage;

const tags =
  (page &&
    page.tags?.map((tag) => ({
      id: tag.id,
      name: tag.name,
      slug: tag.slug,
    }))) ||
  undefined;

const bodyClass = BodyClass({ page, tags });
const isFullBleed = bodyClass.includes("tag-layout-fullbleed");
---

{
  isFullBleed ? (
    <FullPageLayout post={page} bodyClass={bodyClass} />
  ) : (
    <PageLayout post={page} bodyClass={bodyClass} />
  )
}
