---
import { getAllConsultingPages } from "@/utils/ghost";
import ConsultingLayout from "@/layouts/ConsultingLayout.astro";
import { BodyClass } from "@/utils/BodyClass";

export async function getStaticPaths() {
  const pages = await getAllConsultingPages();

  return pages.map((page) => {
    return {
      params: {
        slug: page.slug,
      },
      props: {
        page: page,
      },
    };
  });
}

const { page } = Astro.props;
const tags =
  (page &&
    page.tags?.map((tag) => ({
      id: tag.id,
      name: tag.name,
      slug: tag.slug,
    }))) ||
  undefined;

const bodyClass = BodyClass({ isPost: true, tags });
---

<ConsultingLayout post={page} bodyClass={bodyClass} />
