---
import { getAsidePosts } from '@/utils/ghost'
import { BodyClass } from '@/utils/BodyClass'
import PostLayout from '@/layouts/PostLayout.astro'

export async function getStaticPaths() {
  const pages = await getAsidePosts()

  return pages.posts.map(page => {
    return {
      params: {
        slug: page.slug,
      },
      props: {
        page: page,
      },
    }
  })
}

const { page } = Astro.props
const tags =
  (page &&
    page.tags?.map(tag => ({
      id: tag.id,
      name: tag.name,
      slug: tag.slug,
    }))) ||
  undefined

const bodyClass = BodyClass({ isPost: true, tags })
---

<PostLayout post={page} bodyClass={bodyClass} />
